provider: gitcode # or atomgit
workspace: "/path/to/local/repo"

source:
  # Commits are read from this repository branch. MR branches are pushed back
  # to the same repository.
  # Use atomgit.com/... full paths with provider: atomgit.
  repo: "gitcode.com/your_namespace/project"
  branch: "queue"
  # Optional precise range. If omitted, mr-queue uses target..source.
  # range: "a3c47d5f^..e34a0a61"
  # start_sha: "a3c47d5f"
  # end_sha: "e34a0a61"

target:
  # MRs are created into this repository branch.
  repo: "gitcode.com/community/project"
  branch: "master"

mr:
  branch_prefix: "mr-queue"
  # Placeholders: {prefix}, {title}, {title_or_sha12}, {sha12}, {sha}.
  # Default is "{prefix}-{sha12}". A readable option is "{prefix}-{title_or_sha12}".
  branch_template: "{prefix}-{sha12}"

workflow:
  merge_method: "squash"
  review_comment: "已完成预审，确认合并。"
  wait_check_delay_min: "10s"
  wait_check_delay_max: "30s"
  next_pr_delay_min: "1m"
  next_pr_delay_max: "5m"
  stop_on_failure: true

auth:
  submitter:
    token_env: "GITCODE_SUBMITTER_TOKEN"
  reviewer:
    token_env: "GITCODE_REVIEWER_TOKEN"
  maintainer:
    token_env: "GITCODE_MAINTAINER_TOKEN"
